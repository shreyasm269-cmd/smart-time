rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Validation ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid']) &&
             data.uid is string && data.uid.size() <= 128 &&
             ( !('email' in data) || data.email == null || (data.email is string && data.email.size() <= 256) ) &&
             ( !('createdAt' in data) || data.createdAt == null || data.createdAt is string );
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().uid == existing().uid;
      
      // Events Subcollection
      match /events/{eventId} {
        function isValidEvent(data) {
          return data.keys().hasAll(['title', 'type', 'startTime', 'endTime']) &&
                 data.title is string && data.title.size() <= 200 &&
                 data.type in ['class', 'exam', 'study', 'personal', 'assignment_deadline', 'other'] &&
                 data.startTime is string &&
                 data.endTime is string &&
                 ( !('location' in data) || data.location == null || data.location is string ) &&
                 ( !('description' in data) || data.description == null || data.description is string ) &&
                 ( !('recurrence' in data) || data.recurrence == null || data.recurrence is map );
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidEvent(incoming());
        allow update: if isOwner(userId) && isValidEvent(incoming());
        allow delete: if isOwner(userId);
      }

      // Assignments Subcollection
      match /assignments/{assignmentId} {
        function isValidAssignment(data) {
          return data.keys().hasAll(['title', 'dueDate', 'status']) &&
                 data.title is string && data.title.size() <= 200 &&
                 data.status in ['todo', 'in_progress', 'completed'] &&
                 ( !('subject' in data) || data.subject is string ) &&
                 ( !('priority' in data) || data.priority in ['low', 'medium', 'high'] );
        }

        allow list: if isOwner(userId);
        allow get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidAssignment(incoming());
        allow update: if isOwner(userId) && isValidAssignment(incoming());
        allow delete: if isOwner(userId);
      }

      // Messages Subcollection
      match /messages/{messageId} {
        function isValidMessage(data) {
          return data.keys().hasAll(['text', 'role', 'timestamp']) &&
                 data.text is string && data.text.size() <= 5000 &&
                 data.role in ['user', 'model', 'system'];
        }

        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessage(incoming());
      }
    }
  }
}
